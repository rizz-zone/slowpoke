{
	"name": "slowpoke",
	"module": "index.ts",
	"type": "module",
	"private": true,
	"scripts": {
		"style": "prettier -c .",
		"style:write": "prettier -w .",
		"lint": "eslint .",
		"check-types": "tsc",
		"build": "wrangler deploy --dry-run --outdir=dist",
		"dev": "wrangler dev",
		"register": "bun run utils/register.ts",
		"generate": "bun drizzle-kit generate",
		"migrate": "bun wrangler d1 migrations apply slowpoke-global-db"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.5",
		"@eslint/js": "^10.0.1",
		"@types/bun": "latest",
		"bun-types": "^1.3.12",
		"drizzle-kit": "^0.31.10",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"globals": "^17.5.0",
		"prettier": "^3.8.3",
		"typescript-eslint": "^8.58.2",
		"wrangler": "^4.83.0"
	},
	"peerDependencies": {
		"typescript": "^6.0.3"
	},
	"dependencies": {
		"discord-api-types": "^0.38.47",
		"discord-interactions": "^4.4.0",
		"discord.js": "^14.26.3",
		"drizzle-orm": "^0.45.2",
		"http-status-codes": "^2.3.0",
		"ms": "^4.0.0-nightly.202508271359"
	}
}
